# Copy to .env and fill when Supabase project is ready.
# Never commit .env — it is gitignored.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional for MVP demos. Use digits only or E.164 without spaces, e.g. 41791234567.
EXPO_PUBLIC_BARBER_WHATSAPP=41791234567
