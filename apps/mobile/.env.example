# Copy to .env and fill when Supabase project is ready.
# Never commit .env — it is gitignored.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: set to true to require Supabase login for Admin-Demo (see supabase/README.md)
# EXPO_PUBLIC_ADMIN_AUTH_REQUIRED=true

# Barber WhatsApp (digits only or E.164 without spaces), e.g. 41791234567
EXPO_PUBLIC_WHATSAPP_PHONE=41791234567

# Legacy alias (optional)
EXPO_PUBLIC_BARBER_WHATSAPP=41791234567
